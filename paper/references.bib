@misc{rottgerQuantifyingDistortiveImpacts2025,
  title = {Quantifying the {{Distortive Impacts}} of {{LLM Writing Assistance}}},
  author = {R{\"o}ttger, Paul and Hackenburg, Kobi and Kirk, Hannah Rose and Hovy, Dirk and Summerfield, Chris},
  year = 2025,
  publisher = {OSF Registries},
  doi = {10.17605/OSF.IO/6EXF2},
  urldate = {2026-04-09},
  abstract = {Our study investigates whether the use of Large Language Models (LLMs) for writing assistance systematically distorts how others perceive LLM users and the opinions they express. The study employs a two-phase design: In Phase 1 (Writing), participants ("writers'') report their demographic characteristics and then respond to political propositions by providing numeric stance ratings, opinion bullet points and opinion paragraphs. Writers also report their emotional states while writing, their issue knowledge and how important each issue is to them. For each proposition, each writer is then randomly assigned to one of three LLMs, which generates a version of the writer's opinion paragraph based on one of three randomly assigned input conditions. Writers can edit these AI-generated paragraphs and select which version they prefer for communicating their views. In Phase 2 (Rating), participants ("raters''), who are distinct from the Phase 1 writers, evaluate the paragraphs produced in Phase 1, without knowing the provenance of the paragraphs. Raters assess paragraph attributes (e.g. originality), make inferences about writer attributes (e.g. issue knowledge), writer personality traits (e.g. optimism), as well as writer demographics and emotional states. This design allows for measuring systematic differences in how human-written versus AI-assisted content is perceived, quantifying potential distortive effects of LLM writing assistance.},
  archiveprefix = {OSF Registries},
  collaborator = {{Center For Open Science}},
  copyright = {Creative Commons Attribution Share Alike 4.0 International},
  keywords = {Computer Sciences,FOS: Political science,FOS: Psychology,Physical Sciences and Mathematics,Political Science,Psychology,Social and Behavioral Sciences}
}

@misc{laurerBuildingEfficientUniversal2024,
  title = {Building {{Efficient Universal Classifiers}} with {{Natural Language Inference}}},
  author = {Laurer, Moritz and van Atteveldt, Wouter and Casas, Andreu and Welbers, Kasper},
  year = 2024,
  month = mar,
  number = {arXiv:2312.17543},
  eprint = {2312.17543},
  primaryclass = {cs},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2312.17543},
  urldate = {2026-04-27},
  abstract = {Generative Large Language Models (LLMs) have become the mainstream choice for fewshot and zeroshot learning thanks to the universality of text generation. Many users, however, do not need the broad capabilities of generative LLMs when they only want to automate a classification task. Smaller BERT-like models can also learn universal tasks, which allow them to do any text classification task without requiring fine-tuning (zeroshot classification) or to learn new tasks with only a few examples (fewshot), while being significantly more efficient than generative LLMs. This paper (1) explains how Natural Language Inference (NLI) can be used as a universal classification task that follows similar principles as instruction fine-tuning of generative LLMs, (2) provides a step-by-step guide with reusable Jupyter notebooks for building a universal classifier, and (3) shares the resulting universal classifier that is trained on 33 datasets with 389 diverse classes. Parts of the code we share has been used to train our older zeroshot classifiers that have been downloaded more than 55 million times via the Hugging Face Hub as of December 2023. Our new classifier improves zeroshot performance by 9.4\%.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Artificial Intelligence,Computer Science - Computation and Language},
  file = {/Users/daxmavy/Zotero/storage/GCJV9U8R/Laurer et al. - 2024 - Building Efficient Universal Classifiers with Natural Language Inference.pdf;/Users/daxmavy/Zotero/storage/IKAY8UVM/2312.html}
}

